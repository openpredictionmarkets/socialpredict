#!/usr/bin/env bash

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
DEFAULT_CONFIG_FILE="$HOME/.keys/openpredictionmarkets/hostops.env"

print_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

usage() {
  cat <<'EOF'
Usage: ./HostOps COMMAND

Purpose:
  Host and infrastructure orchestration wrapper.
  This tool SHOULD orchestrate remote operations and cloud workflows.
  It MUST NOT reimplement app runtime logic owned by ./SocialPredict.

Commands:
  host ssh <staging|production>   Open SSH session to known host
  host env get <env> <KEY>        (Planned) Read remote .env key
  host logs <env> <service>       (Planned) Tail remote service logs
  deploy <env>                    (Planned) Orchestrate remote ./SocialPredict deploy
  tf <plan|apply|destroy> <env>   (Planned) Terraform wrapper
  help                            Show this help

Current implementation:
  - host ssh is implemented
  - all other commands are scaffold placeholders

Configuration file:
  HostOps loads this file if it exists:
    ~/.keys/openpredictionmarkets/hostops.env

  Override with:
    HOSTOPS_CONFIG=/path/to/hostops.env ./HostOps ...

  This file is local to your machine and should not be committed.

Conventions:
  staging host defaults to: kconfs.com
  production host defaults to: brierfoxforecast.com
  key path defaults to: ~/.keys/openpredictionmarkets/<env>/id_ed25519
  SSH user defaults to: root
  SSH port defaults to: 22

Per-environment setup keys:
  HOSTOPS_<ENV>_HOST       domain or IP address, e.g. kconfs.com
  HOSTOPS_<ENV>_HOST_IP    optional raw IP fallback/documentation value
  HOSTOPS_<ENV>_USER       SSH user, e.g. root
  HOSTOPS_<ENV>_PORT       SSH port, e.g. 22
  HOSTOPS_<ENV>_KEY        private key path
  HOSTOPS_<ENV>_REPO_PATH  remote repo path, planned deploy/env/log commands

Example:
  # ~/.keys/openpredictionmarkets/hostops.env
  HOSTOPS_STAGING_HOST=kconfs.com
  HOSTOPS_STAGING_HOST_IP=203.0.113.10
  HOSTOPS_STAGING_USER=root
  HOSTOPS_STAGING_PORT=22
  HOSTOPS_STAGING_KEY=~/.keys/openpredictionmarkets/staging/id_ed25519
  HOSTOPS_STAGING_REPO_PATH=/opt/socialpredict
EOF
}

require_planned() {
  print_warn "This subcommand is scaffolded but not implemented yet."
  print_warn "See README/HOSTOPS.md for intended behavior and conventions."
  exit 2
}

expand_home() {
  local p="$1"
  if [[ "$p" == "~"* ]]; then
    echo "${p/#\~/$HOME}"
  else
    echo "$p"
  fi
}

load_config() {
  local config="${HOSTOPS_CONFIG:-$DEFAULT_CONFIG_FILE}"
  config="$(expand_home "$config")"

  if [[ -n "${HOSTOPS_CONFIG:-}" && ! -f "$config" ]]; then
    print_error "HOSTOPS_CONFIG was set, but file was not found: $config"
    exit 1
  fi

  if [[ -f "$config" ]]; then
    # shellcheck source=/dev/null
    source "$config"
  fi
}

default_host_for_env() {
  local env="$1"
  case "$env" in
    staging) echo "kconfs.com" ;;
    production) echo "brierfoxforecast.com" ;;
    *)
      print_error "Unknown environment '$env'. Use 'staging' or 'production'."
      exit 1
      ;;
  esac
}

env_to_key() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_'
}

ssh_to_env() {
  local env="$1"

  local default_host
  default_host="$(default_host_for_env "$env")"

  local env_key
  env_key="$(env_to_key "$env")"

  local host_var="HOSTOPS_${env_key}_HOST"
  local user_var="HOSTOPS_${env_key}_USER"
  local port_var="HOSTOPS_${env_key}_PORT"
  local key_var="HOSTOPS_${env_key}_KEY"

  local host="${!host_var:-$default_host}"
  local user="${!user_var:-root}"
  local port="${!port_var:-22}"
  local key="${!key_var:-~/.keys/openpredictionmarkets/${env}/id_ed25519}"
  key="$(expand_home "$key")"

  if [[ ! -f "$key" ]]; then
    print_error "SSH key not found: $key"
    echo "Set ${key_var} or create the default key path."
    exit 1
  fi

  print_info "Connecting to ${env}: ${user}@${host}"
  print_info "Using port: ${port}"
  print_info "Using key: ${key}"
  exec ssh -i "$key" -p "$port" "${user}@${host}"
}

main() {
  load_config

  local cmd="${1:-help}"

  case "$cmd" in
    help|--help|-h)
      usage
      ;;
    host)
      local sub="${2:-}"
      case "$sub" in
        ssh)
          local env="${3:-}"
          if [[ -z "$env" ]]; then
            print_error "Usage: ./HostOps host ssh <staging|production>"
            exit 1
          fi
          ssh_to_env "$env"
          ;;
        env|get|logs|run)
          require_planned
          ;;
        *)
          print_error "Unknown host subcommand: '${sub:-<none>}'"
          usage
          exit 1
          ;;
      esac
      ;;
    deploy|tf)
      require_planned
      ;;
    *)
      print_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
