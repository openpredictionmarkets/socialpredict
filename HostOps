#!/usr/bin/env bash

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
CONFIG_ROOT="${HOSTOPS_CONFIG_ROOT:-$HOME/.keys/socialpredict}"

print_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

usage() {
  cat <<'EOF'
Usage: ./HostOps COMMAND

Purpose:
  Host and infrastructure orchestration wrapper.
  This tool SHOULD orchestrate remote operations and cloud workflows.
  It MUST NOT reimplement app runtime logic owned by ./SocialPredict.

Commands:
  env help                        Show environment command help
  env list                        List local environments under ~/.keys/socialpredict
  env get <env> <KEY>             Read remote .env key
  host help                       Show host command help
  host ssh <env>                  Open SSH session to environment host
  host env get <env> <KEY>        Read remote .env key (alias)
  host disk <env>                 Show host disk and Docker usage
  host cleanup <env>              Run remote ./SocialPredict cleanup docker
  host logs <env> <service>       (Planned) Tail remote service logs
  deploy <env>                    (Planned) Orchestrate remote ./SocialPredict deploy
  tf <plan|apply|destroy> <env>   (Planned) Terraform wrapper
  help                            Show this help

Current implementation:
  - env list is implemented
  - env get is implemented
  - host ssh is implemented
  - host env get is implemented as an alias
  - host disk is implemented
  - host cleanup is implemented
  - all other commands are scaffold placeholders

Environment directories:
  HostOps treats each directory under ~/.keys/socialpredict as an environment:
    ~/.keys/socialpredict/<env>/

  This lets your local setup mirror your cloud/host setup. For this project,
  expected names are staging for kconfs.com and mo for brierfoxforecast.com.
  Other users may choose dev, prod, demo, site, or any other environment name.

  List configured local environments with:
    ./HostOps env list

Configuration file:
  HostOps loads this file for the requested environment if it exists:
    ~/.keys/socialpredict/<env>/hostops.env

  Override with:
    HOSTOPS_CONFIG=/path/to/hostops.env ./HostOps ...
    HOSTOPS_CONFIG_ROOT=/path/to/root ./HostOps ...

  This file is local to your machine and should not be committed.

Conventions:
  staging host defaults to: kconfs.com
  mo host defaults to: brierfoxforecast.com
  key path defaults to: ~/.keys/socialpredict/<env>/id_ed25519
  SSH user defaults to: root
  SSH port defaults to: 22

Per-environment setup keys in ~/.keys/socialpredict/<env>/hostops.env:
  HOSTOPS_HOST             domain or IP address, e.g. kconfs.com
  HOSTOPS_HOST_IP          optional raw IP fallback/documentation value
  HOSTOPS_USER             SSH user, e.g. root
  HOSTOPS_PORT             SSH port, e.g. 22
  HOSTOPS_KEY              private key path
  HOSTOPS_REPO_PATH        remote repo path, planned deploy/env/log commands

Shell overrides also work:
  HOSTOPS_<ENV>_HOST       domain or IP address, e.g. kconfs.com
  HOSTOPS_<ENV>_HOST_IP    optional raw IP fallback/documentation value
  HOSTOPS_<ENV>_USER       SSH user, e.g. root
  HOSTOPS_<ENV>_PORT       SSH port, e.g. 22
  HOSTOPS_<ENV>_KEY        private key path
  HOSTOPS_<ENV>_REPO_PATH  remote repo path, planned deploy/env/log commands

Examples:
  ./HostOps env help
  ./HostOps env list
  ./HostOps env get staging ADMIN_PASSWORD
  ./HostOps host help
  ./HostOps host ssh staging
  ./HostOps host env get staging ADMIN_PASSWORD
  ./HostOps host disk staging
  ./HostOps host cleanup staging
  ./HostOps host cleanup staging --all-images

Example:
  # ~/.keys/socialpredict/staging/hostops.env
  HOSTOPS_HOST=kconfs.com
  HOSTOPS_HOST_IP=203.0.113.10
  HOSTOPS_USER=root
  HOSTOPS_PORT=22
  HOSTOPS_KEY=~/.keys/socialpredict/staging/id_ed25519
  HOSTOPS_REPO_PATH=/opt/socialpredict

Staging SSH setup:
  mkdir -p ~/.keys/socialpredict/staging
  ssh-keygen -t ed25519 -f ~/.keys/socialpredict/staging/id_ed25519 -C "socialpredict-staging-hostops"
  chmod 600 ~/.keys/socialpredict/staging/id_ed25519

  Add the public key on the VPS user's authorized_keys:
    ~/.keys/socialpredict/staging/id_ed25519.pub
    -> root@kconfs.com:~/.ssh/authorized_keys

  For another environment, use that environment's directory and host.
EOF
}

env_usage() {
  cat <<'EOF'
Usage: ./HostOps env COMMAND

Environment commands manage local HostOps environment definitions under:
  ~/.keys/socialpredict/<env>/

Commands:
  help                  Show this help
  list                  List local environments
  get <env> <KEY>       Read a KEY=value line from the remote app .env file

Examples:
  ./HostOps env list
  ./HostOps env get staging ADMIN_PASSWORD

Notes:
  env get uses SSH and reads from HOSTOPS_REPO_PATH/.env on the remote host.
  The older './HostOps host env get <env> <KEY>' command remains an alias.
EOF
}

env_get_usage() {
  cat <<'EOF'
Usage: ./HostOps env get <env> <KEY>

Read a KEY=value line from the remote app .env file for a configured host.

Examples:
  ./HostOps env get staging ADMIN_PASSWORD
  ./HostOps env get mo ADMIN_PASSWORD
  ./HostOps host env get staging ADMIN_PASSWORD

Notes:
  Environment definitions live under ~/.keys/socialpredict/<env>/.
  The remote file is read from HOSTOPS_REPO_PATH/.env.
  The older './HostOps host env get <env> <KEY>' command remains an alias.
EOF
}

host_usage() {
  cat <<'EOF'
Usage: ./HostOps host COMMAND

Host commands connect to or inspect configured remote hosts.

Commands:
  help                         Show this help
  ssh <env>                    Open SSH session to environment host
  env help                     Show remote environment-file command help
  env get <env> <KEY>          Read remote .env key; alias for './HostOps env get'
  disk <env>                   Show host disk and Docker usage
  cleanup <env> [OPTIONS]      Run remote './SocialPredict cleanup docker'
  logs <env> <service>         Planned

Examples:
  ./HostOps host ssh staging
  ./HostOps host env get staging ADMIN_PASSWORD
  ./HostOps host disk staging
  ./HostOps host cleanup staging --all-images
EOF
}

host_env_usage() {
  cat <<'EOF'
Usage: ./HostOps host env COMMAND

Remote environment-file commands read app configuration on a configured host.

Commands:
  help                  Show this help
  get <env> <KEY>       Read a KEY=value line from HOSTOPS_REPO_PATH/.env

Examples:
  ./HostOps host env get staging ADMIN_PASSWORD
  ./HostOps env get staging ADMIN_PASSWORD

Notes:
  './HostOps env get <env> <KEY>' is the preferred shorter form.
EOF
}

deploy_usage() {
  cat <<'EOF'
Usage: ./HostOps deploy <env>

Planned command. Intended to orchestrate remote SocialPredict deployment without
reimplementing app runtime logic owned by ./SocialPredict.
EOF
}

tf_usage() {
  cat <<'EOF'
Usage: ./HostOps tf <plan|apply|destroy> <env>

Planned command. Intended to wrap Terraform workflows for a selected HostOps
environment.
EOF
}

require_planned() {
  print_warn "This subcommand is scaffolded but not implemented yet."
  print_warn "See README/INFRA/README-INFRA-HOSTOPS.md for intended behavior and conventions."
  exit 2
}

expand_home() {
  local p="$1"
  if [[ "$p" == "~"* ]]; then
    echo "${p/#\~/$HOME}"
  else
    echo "$p"
  fi
}

value_for_name() {
  local name="$1"
  printf '%s' "${!name-}"
}

load_config_for_env() {
  local env="$1"
  local config="${HOSTOPS_CONFIG:-$(env_config_path "$env")}"
  config="$(expand_home "$config")"

  if [[ -n "${HOSTOPS_CONFIG:-}" && ! -f "$config" ]]; then
    print_error "HOSTOPS_CONFIG was set, but file was not found: $config"
    exit 1
  fi

  if [[ -f "$config" ]]; then
    # shellcheck source=/dev/null
    source "$config"
  fi
}

default_host_for_env() {
  local env="$1"
  case "$env" in
    staging) echo "kconfs.com" ;;
    mo|production|prod) echo "brierfoxforecast.com" ;;
    *) echo "" ;;
  esac
}

env_config_path() {
  local env="$1"
  echo "$CONFIG_ROOT/${env}/hostops.env"
}

env_default_key_path() {
  local env="$1"
  echo "$CONFIG_ROOT/${env}/id_ed25519"
}

env_to_key() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_'
}

resolve_env_connection() {
  local env="$1"

  load_config_for_env "$env"

  local env_key
  env_key="$(env_to_key "$env")"

  local host_var="HOSTOPS_${env_key}_HOST"
  local host_ip_var="HOSTOPS_${env_key}_HOST_IP"
  local user_var="HOSTOPS_${env_key}_USER"
  local port_var="HOSTOPS_${env_key}_PORT"
  local key_var="HOSTOPS_${env_key}_KEY"
  local repo_path_var="HOSTOPS_${env_key}_REPO_PATH"

  local env_host env_host_ip env_user env_port env_key_value env_repo_path
  env_host="$(value_for_name "$host_var")"
  env_host_ip="$(value_for_name "$host_ip_var")"
  env_user="$(value_for_name "$user_var")"
  env_port="$(value_for_name "$port_var")"
  env_key_value="$(value_for_name "$key_var")"
  env_repo_path="$(value_for_name "$repo_path_var")"

  local default_host
  default_host="$(default_host_for_env "$env")"

  HOSTOPS_RESOLVED_HOST="${HOSTOPS_HOST:-}"
  if [[ -z "$HOSTOPS_RESOLVED_HOST" ]]; then HOSTOPS_RESOLVED_HOST="$env_host"; fi
  if [[ -z "$HOSTOPS_RESOLVED_HOST" ]]; then HOSTOPS_RESOLVED_HOST="${HOSTOPS_HOST_IP:-}"; fi
  if [[ -z "$HOSTOPS_RESOLVED_HOST" ]]; then HOSTOPS_RESOLVED_HOST="$env_host_ip"; fi
  if [[ -z "$HOSTOPS_RESOLVED_HOST" ]]; then HOSTOPS_RESOLVED_HOST="$default_host"; fi

  HOSTOPS_RESOLVED_USER="${HOSTOPS_USER:-}"
  if [[ -z "$HOSTOPS_RESOLVED_USER" ]]; then HOSTOPS_RESOLVED_USER="$env_user"; fi
  if [[ -z "$HOSTOPS_RESOLVED_USER" ]]; then HOSTOPS_RESOLVED_USER="root"; fi

  HOSTOPS_RESOLVED_PORT="${HOSTOPS_PORT:-}"
  if [[ -z "$HOSTOPS_RESOLVED_PORT" ]]; then HOSTOPS_RESOLVED_PORT="$env_port"; fi
  if [[ -z "$HOSTOPS_RESOLVED_PORT" ]]; then HOSTOPS_RESOLVED_PORT="22"; fi

  HOSTOPS_RESOLVED_KEY="${HOSTOPS_KEY:-}"
  if [[ -z "$HOSTOPS_RESOLVED_KEY" ]]; then HOSTOPS_RESOLVED_KEY="$env_key_value"; fi
  if [[ -z "$HOSTOPS_RESOLVED_KEY" ]]; then HOSTOPS_RESOLVED_KEY="$(env_default_key_path "$env")"; fi
  HOSTOPS_RESOLVED_KEY="$(expand_home "$HOSTOPS_RESOLVED_KEY")"

  HOSTOPS_RESOLVED_REPO_PATH="${HOSTOPS_REPO_PATH:-}"
  if [[ -z "$HOSTOPS_RESOLVED_REPO_PATH" ]]; then HOSTOPS_RESOLVED_REPO_PATH="$env_repo_path"; fi
  if [[ -z "$HOSTOPS_RESOLVED_REPO_PATH" ]]; then HOSTOPS_RESOLVED_REPO_PATH="/opt/socialpredict"; fi

  if [[ -z "$HOSTOPS_RESOLVED_HOST" ]]; then
    print_error "No host configured for environment '$env'."
    echo "Create ~/.keys/socialpredict/${env}/hostops.env with HOSTOPS_HOST=..."
    exit 1
  fi

  if [[ ! -f "$HOSTOPS_RESOLVED_KEY" ]]; then
    print_error "SSH key not found: $HOSTOPS_RESOLVED_KEY"
    echo "Set HOSTOPS_KEY, set ${key_var}, or create the default key path."
    exit 1
  fi
}

list_envs() {
  local root
  root="$(expand_home "$CONFIG_ROOT")"

  if [[ ! -d "$root" ]]; then
    print_warn "No HostOps environment root found: $root"
    echo "Create directories such as:"
    echo "  ~/.keys/socialpredict/staging"
    echo "  ~/.keys/socialpredict/mo"
    echo
    echo "Each directory can contain:"
    echo "  hostops.env"
    echo "  id_ed25519"
    return 0
  fi

  local found=0
  local env_dir env config key host

  printf '%-18s %-28s %-8s %-8s %s\n' "ENV" "HOST" "CONFIG" "KEY" "PATH"

  for env_dir in "$root"/*; do
    [[ -d "$env_dir" ]] || continue
    found=1
    env="$(basename "$env_dir")"
    config="$env_dir/hostops.env"
    key="$env_dir/id_ed25519"
    host="$(default_host_for_env "$env")"

    if [[ -f "$config" ]]; then
      host="$(
        HOSTOPS_HOST=
        HOSTOPS_HOST_IP=
        # shellcheck source=/dev/null
        source "$config"
        printf '%s' "${HOSTOPS_HOST:-${HOSTOPS_HOST_IP:-$host}}"
      )"
      key="$(
        HOSTOPS_KEY=
        # shellcheck source=/dev/null
        source "$config"
        printf '%s' "${HOSTOPS_KEY:-$key}"
      )"
      key="$(expand_home "$key")"
    fi

    printf '%-18s %-28s %-8s %-8s %s\n' \
      "$env" \
      "${host:-<unset>}" \
      "$([[ -f "$config" ]] && echo yes || echo no)" \
      "$([[ -f "$key" ]] && echo yes || echo no)" \
      "$env_dir"
  done

  if [[ "$found" -eq 0 ]]; then
    print_warn "No HostOps environments found under: $root"
    echo "Create a directory like ~/.keys/socialpredict/staging to define an environment."
  fi
}

ssh_to_env() {
  local env="$1"

  resolve_env_connection "$env"

  print_info "Connecting to ${env}: ${HOSTOPS_RESOLVED_USER}@${HOSTOPS_RESOLVED_HOST}"
  print_info "Using port: ${HOSTOPS_RESOLVED_PORT}"
  print_info "Using key: ${HOSTOPS_RESOLVED_KEY}"
  exec ssh -i "$HOSTOPS_RESOLVED_KEY" -p "$HOSTOPS_RESOLVED_PORT" "${HOSTOPS_RESOLVED_USER}@${HOSTOPS_RESOLVED_HOST}"
}

host_env_get() {
  local env="$1"
  local requested_key="$2"

  if [[ ! "$requested_key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    print_error "Invalid environment key: $requested_key"
    echo "Keys must match: ^[A-Za-z_][A-Za-z0-9_]*$"
    exit 1
  fi

  resolve_env_connection "$env"

  ssh -i "$HOSTOPS_RESOLVED_KEY" \
    -o BatchMode=yes \
    -p "$HOSTOPS_RESOLVED_PORT" \
    "${HOSTOPS_RESOLVED_USER}@${HOSTOPS_RESOLVED_HOST}" \
    "REPO_PATH='$HOSTOPS_RESOLVED_REPO_PATH' REQUESTED_KEY='$requested_key' bash -s" <<'REMOTE'
set -euo pipefail
env_file="${REPO_PATH}/.env"
if [[ ! -f "$env_file" ]]; then
  echo "Remote .env file not found: $env_file" >&2
  exit 1
fi
grep -E "^${REQUESTED_KEY}=" "$env_file" || {
  echo "Key not found in $env_file: $REQUESTED_KEY" >&2
  exit 1
}
REMOTE
}

host_disk() {
  local env="$1"

  resolve_env_connection "$env"

  ssh -i "$HOSTOPS_RESOLVED_KEY" \
    -o BatchMode=yes \
    -p "$HOSTOPS_RESOLVED_PORT" \
    "${HOSTOPS_RESOLVED_USER}@${HOSTOPS_RESOLVED_HOST}" \
    "REPO_PATH='$HOSTOPS_RESOLVED_REPO_PATH' bash -s" <<'REMOTE'
set -euo pipefail
echo "Host disk usage:"
df -h /
echo
echo "Docker disk usage:"
docker system df || true
echo
echo "Running containers:"
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" || true
echo
echo "Docker volumes:"
docker volume ls || true
REMOTE
}

host_cleanup() {
  local env="$1"
  shift || true

  local cleanup_args=()
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --all-images|--volumes)
        cleanup_args+=("$1")
        ;;
      --help|-h)
        cat <<'EOF'
Usage: ./HostOps host cleanup <env> [OPTIONS]

Run remote './SocialPredict cleanup docker' on the selected host.

Options:
  --all-images   Remove all unused images, not just dangling images
  --volumes      Also prune unused Docker volumes; use carefully on data hosts
  --help         Show this help

Examples:
  ./HostOps host cleanup staging
  ./HostOps host cleanup staging --all-images
  ./HostOps host cleanup staging --all-images --volumes

Boundary:
  HostOps only connects to the host and invokes ./SocialPredict. The Docker
  cleanup behavior remains owned by ./SocialPredict.
EOF
        return 0
        ;;
      *)
        print_error "Unknown host cleanup option: $1"
        exit 1
        ;;
    esac
    shift
  done

  resolve_env_connection "$env"

  local quoted_cleanup_args=""
  local arg
  for arg in "${cleanup_args[@]}"; do
    quoted_cleanup_args+=" $(printf "%q" "$arg")"
  done

  ssh -i "$HOSTOPS_RESOLVED_KEY" \
    -o BatchMode=yes \
    -p "$HOSTOPS_RESOLVED_PORT" \
    "${HOSTOPS_RESOLVED_USER}@${HOSTOPS_RESOLVED_HOST}" \
    "cd $(printf "%q" "$HOSTOPS_RESOLVED_REPO_PATH") && ./SocialPredict cleanup docker${quoted_cleanup_args}"
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    help|--help|-h)
      usage
      ;;
    env)
      local sub="${2:-}"
      case "$sub" in
        help|--help|-h|"")
          env_usage
          ;;
        list)
          list_envs
          ;;
        get)
          local env="${3:-}"
          local requested_key="${4:-}"
          if [[ -z "$env" || "$env" == "help" || "$env" == "--help" || "$env" == "-h" || "$requested_key" == "help" || "$requested_key" == "--help" || "$requested_key" == "-h" ]]; then
            env_get_usage
            exit 0
          fi
          if [[ -z "$requested_key" ]]; then
            env_get_usage
            exit 0
          fi
          host_env_get "$env" "$requested_key"
          ;;
        *)
          print_error "Unknown env subcommand: '${sub:-<none>}'"
          env_usage
          exit 1
          ;;
      esac
      ;;
    host)
      local sub="${2:-}"
      case "$sub" in
        help|--help|-h|"")
          host_usage
          ;;
        ssh)
          local env="${3:-}"
          if [[ -z "$env" ]]; then
            print_error "Usage: ./HostOps host ssh <env>"
            exit 1
          fi
          ssh_to_env "$env"
          ;;
        env)
          local env_action="${3:-}"
          case "$env_action" in
            help|--help|-h|"")
              host_env_usage
              ;;
            get)
              local env="${4:-}"
              local requested_key="${5:-}"
              if [[ -z "$env" || "$env" == "help" || "$env" == "--help" || "$env" == "-h" || "$requested_key" == "help" || "$requested_key" == "--help" || "$requested_key" == "-h" ]]; then
                env_get_usage
                exit 0
              fi
              if [[ -z "$requested_key" ]]; then
                env_get_usage
                exit 0
              fi
              host_env_get "$env" "$requested_key"
              ;;
            *)
              print_error "Unknown host env subcommand: '${env_action:-<none>}'"
              host_env_usage
              exit 1
              ;;
          esac
          ;;
        disk)
          local env="${3:-}"
          if [[ -z "$env" ]]; then
            print_error "Usage: ./HostOps host disk <env>"
            exit 1
          fi
          host_disk "$env"
          ;;
        cleanup)
          local env="${3:-}"
          if [[ "$env" == "--help" || "$env" == "-h" || "$env" == "help" ]]; then
            host_cleanup "help" --help
            exit 0
          fi
          if [[ -z "$env" ]]; then
            print_error "Usage: ./HostOps host cleanup <env> [--all-images] [--volumes]"
            exit 1
          fi
          shift 3
          host_cleanup "$env" "$@"
          ;;
        get|logs|run)
          require_planned
          ;;
        *)
          print_error "Unknown host subcommand: '${sub:-<none>}'"
          host_usage
          exit 1
          ;;
      esac
      ;;
    deploy)
      case "${2:-}" in
        help|--help|-h) deploy_usage ;;
        *) require_planned ;;
      esac
      ;;
    tf)
      case "${2:-}" in
        help|--help|-h) tf_usage ;;
        *) require_planned ;;
      esac
      ;;
    *)
      print_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
