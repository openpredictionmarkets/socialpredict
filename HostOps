#!/usr/bin/env bash

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

print_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

usage() {
  cat <<'EOF'
Usage: ./HostOps COMMAND

Purpose:
  Host and infrastructure orchestration wrapper.
  This tool SHOULD orchestrate remote operations and cloud workflows.
  It MUST NOT reimplement app runtime logic owned by ./SocialPredict.

Commands:
  host ssh <staging|production>   Open SSH session to known host
  host env get <env> <KEY>        (Planned) Read remote .env key
  host logs <env> <service>       (Planned) Tail remote service logs
  deploy <env>                    (Planned) Orchestrate remote ./SocialPredict deploy
  tf <plan|apply|destroy> <env>   (Planned) Terraform wrapper
  help                            Show this help

Current implementation:
  - host ssh is implemented
  - all other commands are scaffold placeholders

Conventions:
  staging host defaults to: kconfs.com
  production host defaults to: brierfoxforecast.com
  key path defaults to: ~/.keys/openpredictionmarkets/<env>/id_ed25519
EOF
}

require_planned() {
  print_warn "This subcommand is scaffolded but not implemented yet."
  print_warn "See README/HOSTOPS.md for intended behavior and conventions."
  exit 2
}

expand_home() {
  local p="$1"
  if [[ "$p" == "~"* ]]; then
    echo "${p/#\~/$HOME}"
  else
    echo "$p"
  fi
}

default_host_for_env() {
  local env="$1"
  case "$env" in
    staging) echo "kconfs.com" ;;
    production) echo "brierfoxforecast.com" ;;
    *)
      print_error "Unknown environment '$env'. Use 'staging' or 'production'."
      exit 1
      ;;
  esac
}

ssh_to_env() {
  local env="$1"

  local default_host
  default_host="$(default_host_for_env "$env")"

  local host_var="HOSTOPS_${env^^}_HOST"
  local user_var="HOSTOPS_${env^^}_USER"
  local key_var="HOSTOPS_${env^^}_KEY"

  local host="${!host_var:-$default_host}"
  local user="${!user_var:-root}"
  local key="${!key_var:-~/.keys/openpredictionmarkets/${env}/id_ed25519}"
  key="$(expand_home "$key")"

  if [[ ! -f "$key" ]]; then
    print_error "SSH key not found: $key"
    echo "Set ${key_var} or create the default key path."
    exit 1
  fi

  print_info "Connecting to ${env}: ${user}@${host}"
  print_info "Using key: ${key}"
  exec ssh -i "$key" "${user}@${host}"
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    help|--help|-h)
      usage
      ;;
    host)
      local sub="${2:-}"
      case "$sub" in
        ssh)
          local env="${3:-}"
          if [[ -z "$env" ]]; then
            print_error "Usage: ./HostOps host ssh <staging|production>"
            exit 1
          fi
          ssh_to_env "$env"
          ;;
        env|get|logs|run)
          require_planned
          ;;
        *)
          print_error "Unknown host subcommand: '${sub:-<none>}'"
          usage
          exit 1
          ;;
      esac
      ;;
    deploy|tf)
      require_planned
      ;;
    *)
      print_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
